generator client {
  output = "../src/app/generated/prisma"
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Course {
  id       String   @id @default(uuid())
  title    String
  authorId String
  lessons  Lesson[]
}

model Lesson {
  id          String       @id @default(uuid())
  title       String
  contentJson Json
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id])
  annotations Annotation[]
}

enum AnnotationType {
  TOO_COMPLEX
  UNCLEAR_TERM
  NEEDS_EXAMPLE
  TOO_LONG
}

model Annotation {
  id        String         @id @default(uuid())
  blockId   String
  type      AnnotationType
  userId    String
  lessonId  String
  lesson    Lesson         @relation(fields: [lessonId], references: [id])
  createdAt DateTime       @default(now())

  @@unique([blockId, userId, type])
}
